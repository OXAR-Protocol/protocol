# Copy to .env.local and fill in.
# .env.local is gitignored.

# Required: Alchemy mainnet API key (free tier OK for v0.1)
ALCHEMY_API_KEY=

# Required: Anthropic API key for Claude Haiku explain layer
ANTHROPIC_API_KEY=

# Optional: Helius mainnet API key. Required only for Solana wallet analysis.
# Solana adapter is wired but no Solana RWA mints are in the registry yet;
# Phase 2 / OXAR mainnet launch adds them.
HELIUS_API_KEY=

# Required: Supabase project (shared with the OXAR waitlist Supabase).
# Radar lives in the `radar` schema; waitlist stays in `public`.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required: Postgres password for the pooler connection. Found in
# Supabase Dashboard → Project Settings → Database.
# Radar uses direct postgres via the EU-West-1 pooler instead of
# PostgREST so we don't need to expose the `radar` schema in the API.
SUPABASE_DB_PASSWORD=

# Optional: per-IP rate limit for the public /analyze endpoint
RATE_LIMIT_REQUESTS_PER_WINDOW=5
RATE_LIMIT_WINDOW_MS=600000

# Optional: shared secret for /api/cron/* endpoints.
# Vercel Cron sends "Authorization: Bearer <CRON_SECRET>" automatically.
# Leave empty in local dev to allow plain curl smoke tests.
CRON_SECRET=

# Optional but recommended: shared secret for /api/admin/* endpoints.
# Used to mint customer API keys until the Phase 3 dashboard ships.
# Set this to a long random string. When unset, admin endpoints return 503.
ADMIN_SECRET=

# Copy to .env.local and fill in.
# .env.local is gitignored.

# Required: Alchemy mainnet API key (free tier OK for v0.1)
ALCHEMY_API_KEY=

# Required: Anthropic API key for Claude Haiku explain layer
ANTHROPIC_API_KEY=

# Optional: Helius mainnet API key. Required only for Solana wallet analysis.
# Solana adapter is wired but no Solana RWA mints are in the registry yet;
# Phase 2 / OXAR mainnet launch adds them.
HELIUS_API_KEY=

# Optional: per-IP rate limit for the public /analyze endpoint
RATE_LIMIT_REQUESTS_PER_WINDOW=5
RATE_LIMIT_WINDOW_MS=600000

# RPC + auth
SOLANA_RPC_URL=https://api.devnet.solana.com
# Path to the keypair that authority-signs crank_nav tx (must have devnet/mainnet SOL).
# In production this should be a dedicated "cranker" wallet, NOT user funds wallet.
CRANKER_KEYPAIR_PATH=/path/to/cranker.json

# Delora — server-only credentials. Same key as web/.env.local DELORA_API_KEY.
DELORA_API_KEY=ppk_xxx
DELORA_BASE_URL=https://api.delora.build/v1
DELORA_INTEGRATOR=oxarforoxar

# Cron interval in seconds. NAV doesn't move fast — 1h is fine for MVP.
CRANK_INTERVAL_SEC=3600

# Optional: limit which vaults to process (comma-separated PDAs).
# Empty = all DeloraCrossChain vaults across all users.
VAULT_ALLOWLIST=

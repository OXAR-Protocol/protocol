# Kora node env — set these as Railway service variables (NOT committed).

# Solana mainnet RPC the node talks to (reuse the app's Helius mainnet URL).
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=REPLACE_ME

# Fee-payer secret key, base58 (output of `solana-keygen`, see README). Server-only.
KORA_SIGNER_KEY=REPLACE_ME_BASE58_SECRET

# Optional but recommended: shared secret the web app sends as x-api-key.
# Also set the SAME value as KORA_API_KEY in the web app (server-side) once wired.
KORA_API_KEY=REPLACE_ME_LONG_RANDOM
